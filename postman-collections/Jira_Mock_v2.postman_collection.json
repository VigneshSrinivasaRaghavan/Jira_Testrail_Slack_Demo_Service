    {
      "name": "Error Cases",
      "description": "Verify the API returns correct error codes. Use these to understand how to handle errors in your AI agent code.",
      "item": [

        {
          "name": "401 – No Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "var json = pm.response.json();",
                  "pm.test('Error detail present', () => pm.expect(json.detail).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "auth": {"type": "noauth"},
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/rest/api/3/issue/QA-1",
              "host": ["{{base_url}}"],
              "path": ["rest", "api", "3", "issue", "QA-1"]
            },
            "description": "Request with **no Authorization header** → should return 401."
          },
          "response": [
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"detail\": \"Missing Authorization header. Required: Authorization: Bearer mock-jira-token-2025\"\n}"
            }
          ]
        },

        {
          "name": "401 – Wrong Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "var json = pm.response.json();",
                  "pm.test('Invalid token message', () => pm.expect(json.detail).to.include('Invalid token'));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{"key": "token", "value": "wrong-token-abc", "type": "string"}]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/rest/api/3/issue/QA-1",
              "host": ["{{base_url}}"],
              "path": ["rest", "api", "3", "issue", "QA-1"]
            },
            "description": "Request with a **wrong Bearer token** → should return 401."
          },
          "response": [
            {
              "name": "401 Wrong Token",
              "status": "Unauthorized",
              "code": 401,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"detail\": \"Invalid token. Only the mock API token is accepted. See /docs for the correct token.\"\n}"
            }
          ]
        },

        {
          "name": "404 – Issue Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "var json = pm.response.json();",
                  "pm.test('Not found message', () => pm.expect(json.detail).to.eql('Issue not found'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/rest/api/3/issue/QA-99999",
              "host": ["{{base_url}}"],
              "path": ["rest", "api", "3", "issue", "QA-99999"]
            },
            "description": "Request for a **non-existent issue key** → should return 404."
          },
          "response": [
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"detail\": \"Issue not found\"\n}"
            }
          ]
        }

      ]
