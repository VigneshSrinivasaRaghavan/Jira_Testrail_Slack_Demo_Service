                  "pm.test('Has key', () => pm.expect(json.key).to.be.a('string'));",
                  "pm.test('Has summary', () => pm.expect(json.fields.summary).to.be.a('string'));",
                  "pm.test('Description is ADF doc', () => pm.expect(json.fields.description.type).to.eql('doc'));",
                  "pm.test('Has status', () => pm.expect(json.fields.status.name).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/rest/api/3/issue/{{issue_key}}",
              "host": ["{{base_url}}"],
              "path": ["rest", "api", "3", "issue", "{{issue_key}}"]
            },
            "description": "Fetch a single issue by key. Uses `{{issue_key}}` variable (auto-set after Create Story).\n\nThe `description` field is returned in **Atlassian Document Format (ADF)** — matching real Jira Cloud."
          },
          "response": []
        },

