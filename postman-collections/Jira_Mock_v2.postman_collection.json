        {
          "name": "Get Transitions (Story)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "pm.test('Has transitions array', () => pm.expect(json.transitions).to.be.an('array'));",
                  "if (json.transitions.length > 0) {",
                  "    pm.environment.set('transition_id', json.transitions[0].id);",
                  "    console.log('Available transitions:', json.transitions.map(t => t.name).join(', '));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/rest/api/3/issue/{{issue_key}}/transitions",
              "host": ["{{base_url}}"],
              "path": ["rest", "api", "3", "issue", "{{issue_key}}", "transitions"]
            },
            "description": "Get the available status transitions for the current issue status.\n\n| Current Status | Available Transitions |\n|---|---|\n| To Do | In Progress |\n| In Progress | Done, To Do |\n| Done | To Do, In Progress |\n\nThe first transition ID is auto-saved to `{{transition_id}}`."
          },
          "response": [
