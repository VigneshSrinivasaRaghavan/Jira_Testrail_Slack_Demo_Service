    {
      "name": "Chat",
      "description": "Send, update and delete messages.\n\nAll requests use: `Authorization: Bearer {{api_token}}`",
      "item": [

        {
          "name": "Send Message",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('ok is true', () => pm.expect(json.ok).to.be.true);",
                  "pm.test('ts returned', () => pm.expect(json.ts).to.be.a('string'));",
                  "pm.test('channel returned', () => pm.expect(json.channel).to.be.a('string'));",
                  "if (json.ok) {",
                  "    pm.environment.set('message_ts', json.ts);",
                  "    console.log('Message ts saved:', json.ts);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"channel\": \"{{channel_name}}\",\n  \"text\": \"This is test message from API\",\n  \"username\": \"MockBot\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/chat.postMessage",
              "host": ["{{base_url}}"],
              "path": ["api", "chat.postMessage"]
            },
            "description": "Send a message to a channel. The channel can be a name (`qa-reports`) or an ID (`C1234567890`).\n\nEquivalent to real Slack's `chat.postMessage`.\n\n**The returned `ts` is auto-saved to `{{message_ts}}`** for use in Update, Delete, Reaction requests.\n\n**Required fields:**\n- `channel` — channel name or ID\n- `text` — message content\n\n**Optional fields:**\n- `username` — display name for the message author\n- `thread_ts` — reply to a thread\n- `attachments` — legacy attachments array\n- `blocks` — Block Kit blocks array"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"ok\": true,\n  \"channel\": \"C1234567890\",\n  \"ts\": \"1774296066.063248\",\n  \"message\": {\n    \"type\": \"message\",\n    \"bot_id\": \"B0MOCKBOT01\",\n    \"text\": \"This is test message from API\",\n    \"user\": \"MockBot\",\n    \"ts\": \"1774296066.063248\",\n    \"team\": \"T0MOCKTEAM1\",\n    \"thread_ts\": null,\n    \"attachments\": [],\n    \"blocks\": []\n  }\n}"
            },
            {
              "name": "200 – channel_not_found",
              "status": "OK",
              "code": 200,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"ok\": false,\n  \"error\": \"channel_not_found\"\n}"
            }
          ]
        },

