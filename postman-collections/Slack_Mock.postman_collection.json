          "name": "List Channels",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('ok is true', () => pm.expect(json.ok).to.be.true);",
                  "pm.test('channels is array', () => pm.expect(json.channels).to.be.an('array'));",
                  "if (json.channels.length > 0) {",
                  "    pm.environment.set('channel_id', json.channels[0].id);",
                  "    console.log('First channel ID saved:', json.channels[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/conversations.list",
              "host": ["{{base_url}}"],
              "path": ["api", "conversations.list"],
              "query": [
                {"key": "limit", "value": "100", "disabled": true},
                {"key": "types", "value": "public_channel", "disabled": true}
