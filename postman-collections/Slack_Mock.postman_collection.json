        {
          "name": "Create Channel",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('ok is true', () => pm.expect(json.ok).to.be.true);",
                  "if (json.ok) {",
                  "    pm.environment.set('channel_id', json.channel.id);",
                  "    pm.environment.set('channel_name', json.channel.name);",
                  "    console.log('Channel created:', json.channel.name, json.channel.id);",
                  "    pm.test('Channel ID returned', () => pm.expect(json.channel.id).to.match(/^C/));",
                  "}"
