              "body": "{\n  \"ok\": true,\n  \"channels\": [\n    {\"id\": \"C1234567890\", \"name\": \"qa-reports\", \"is_channel\": true, \"is_private\": false},\n    {\"id\": \"C0987654321\", \"name\": \"general\", \"is_channel\": true, \"is_private\": false}\n  ],\n  \"response_metadata\": {\"next_cursor\": \"\"}\n}"
